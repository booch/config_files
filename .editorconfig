# Keep this file aligned with the repo's active editor and formatter settings.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 4
max_line_length = off

[*.{json,jsonc}]
indent_style = space
indent_size = 4

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 4

[*.{rb,rake,gemspec,ru,erb}]
indent_style = space
indent_size = 2

[{Gemfile,Rakefile}]
indent_style = space
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab
tab_width = 8

[{COMMIT_EDITMSG,MERGE_MSG,TAG_EDITMSG}]
max_line_length = 80
