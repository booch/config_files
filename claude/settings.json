  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[skill] loading: \" + .tool_input.skill'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/craigbuchek/.local/share/mise/installs/node/23.11.0/bin/node\" \"/Users/craigbuchek/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/craigbuchek/.local/share/mise/installs/bun/1.3.1/bin/bun /Users/craigbuchek/.config/claude/hooks/task-complete-enforcer.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/craigbuchek/.local/share/mise/installs/bun/1.3.1/bin/bun /Users/craigbuchek/.config/claude/hooks/task-complete-reminder.ts"
          }
        ]
      }
    ]
  },
