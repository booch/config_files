# Use a light theme with a nice full color palette.
theme = iTerm2 Tango Light
# Set background to light tan.
background = #ebebd8
# But keep native MacOS title bar style/color.
macos-titlebar-style = native

# Use a larger font for better readability.
font-size = 20

# Start with a 120x30 window size.
window-width = 120
window-height = 30

# Make cursor a bit more visible.
adjust-cursor-thickness = 2

# FIXME: This doesn't seem to work (except in non-focused windows). Maybe there's something in my Zsh startup files.
cursor-style = block

# Hide the mouse immediately when typing.
mouse-hide-while-typing = true

# Allow a **lot** of scrollback buffer. Note that this is in bytes, per tab
# 20 MB per tab seems reasonable, and gets us probably ~100,000 lines.
scrollback-limit = 20000000

# Allow clicking on URLs (with Command) to open them.
link-url = true

# Require confirmation before pasting text that appears unsafe.
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = false

# Don't automatically copy selected text to the clipboard.
copy-on-select = false

# Quit Ghostty 10 seconds after the last window is closed.
quit-after-last-window-closed = true
quit-after-last-window-closed-delay = 10s

# Give a lot more time for operations to stay in the Undo stack.
undo-timeout = 48h

# Enable all shell integration features. Note: ssh-env won't run if ssh-terminfo works.
shell-integration-features = cursor,sudo,title,ssh-terminfo,ssh-env

# Dim unfocused splits a bit more than the default.
unfocused-split-opacity = 0.45
